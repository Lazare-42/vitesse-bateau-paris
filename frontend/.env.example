# Variables NEXT_PUBLIC_* lues à la construction (next build) pour adapter
# le site à une zone autre que Paris. Voir frontend/site.config.ts.
#
# Toutes ces variables sont optionnelles ; les valeurs par défaut couvrent
# la zone Paris.

# Titre dans le <title> et la page d'accueil.
NEXT_PUBLIC_SITE_NAME="Vitesse Bateau Paris"

# Utilisés dans les phrases type "sur la <river> à <city>".
NEXT_PUBLIC_CITY_NAME="Paris"
NEXT_PUBLIC_RIVER_NAME="Seine"

# Forme contractée avec article (pour "Rois de la <...>", "à la <...>", etc.).
NEXT_PUBLIC_RIVER_WITH_ARTICLE="de la Seine"

# Limite de vitesse en km/h. Doit correspondre à speed_limit_knots dans
# le config.toml du backend (knots = km/h ÷ 1.852).
NEXT_PUBLIC_SPEED_LIMIT_KMH=12

# Centre par défaut de la carte (latitude,longitude).
NEXT_PUBLIC_MAP_CENTER="48.8566,2.335"

# Zoom initial de la carte.
NEXT_PUBLIC_MAP_ZOOM=13

# Sous-zones cliquables (JSON sérialisé). Laisser vide ou ne pas définir
# pour masquer la barre de filtre par zone.
# Format : [{"name":"...","bounds":[[swLat,swLon],[neLat,neLon]]}, ...]
# NEXT_PUBLIC_MAP_ZONES='[{"name":"Champigny","bounds":[[48.81,2.51],[48.83,2.55]]}]'
